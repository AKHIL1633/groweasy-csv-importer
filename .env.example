# === apps/api ===

# Port the Express server listens on. Railway/Render inject this
# automatically in production — this default is for local dev only.
PORT=4000

# development | production | test
NODE_ENV=development

# fatal | error | warn | info | debug | trace | silent
# Defaults to "debug" in development, "info" in production if unset.
LOG_LEVEL=debug

# Google Gemini API key (https://aistudio.google.com/apikey). Required.
# Secret — never commit a real value.
GEMINI_API_KEY=

# Max retries per AI batch call on a retryable failure (429/5xx/timeout).
AI_BATCH_MAX_RETRIES=2

# How many batches may call the AI provider concurrently within one import.
# Lower this if a Gemini API key's rate limit is being tripped.
AI_BATCH_CONCURRENCY=3

# Per-request timeout to Gemini, in ms.
AI_REQUEST_TIMEOUT_MS=60000

# Retry backoff curve (exponential + jitter), in ms.
AI_RETRY_BASE_DELAY_MS=500
AI_RETRY_MAX_DELAY_MS=8000

# Comma-separated exact origin(s) allowed to call this API (CORS), e.g.
# https://groweasy-csv-importer.vercel.app for production. Required in
# production — the server refuses to boot without it. Defaults to
# http://localhost:3000 in development only. Never a wildcard.
ALLOWED_ORIGIN=http://localhost:3000

# === apps/web ===

# Base URL of the deployed backend, e.g.
# https://groweasy-csv-api.up.railway.app in production. No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000
